{
  "name": "vscode-pi",
  "displayName": "VSCode Pi Agent Context",
  "description": "Share your open files and selection with a terminal-based Pi agent.",
  "version": "0.0.1",
  "publisher": "zenyui",
  "license": "MIT",
  "icon": "images/icon.png",
  "keywords": [
    "pi-package",
    "pi",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zenyui/vscode-pi.git"
  },
  "pi": {
    "extensions": [
      "pi/pi-vscode-context.ts"
    ]
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "piContext.toggle",
        "title": "Pi Context: Toggle Sharing"
      },
      {
        "command": "piContext.sendToPi",
        "title": "Pi Context: Send Selection to Pi"
      }
    ],
    "keybindings": [
      {
        "command": "piContext.sendToPi",
        "key": "cmd+alt+k",
        "win": "ctrl+alt+k",
        "linux": "ctrl+alt+k",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Pi Agent Context",
      "properties": {
        "piContext.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically share editor context with the Pi agent."
        },
        "piContext.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce delay (ms) before sharing after an editor change."
        },
        "piContext.maxSelectionLines": {
          "type": "number",
          "default": 400,
          "description": "Maximum number of selected lines to include verbatim."
        },
        "piContext.autoInstallCompanion": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install/update the Pi companion extension into ~/.pi/agent/extensions/ on startup."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "watch": "npm run build -- --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  }
}
